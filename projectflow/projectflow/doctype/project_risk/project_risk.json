{
  "name": "Project Risk",
  "module": "ProjectFlow",
  "doctype": "DocType",
  "autoname": "naming_series:",
  "naming_series": "RISK-.YYYY.-.#####",
  "title_field": "risk_name",
  "sort_field": "creation",
  "sort_order": "DESC",
  "fields": [
    {"fieldname": "naming_series", "fieldtype": "Select", "label": "Series", "options": "RISK-.YYYY.-.#####", "hidden": 1},
    {"fieldname": "risk_name", "fieldtype": "Data", "label": "Risk Title", "reqd": 1, "in_list_view": 1},
    {"fieldname": "project", "fieldtype": "Link", "options": "Project", "label": "Project", "reqd": 1, "in_list_view": 1, "in_standard_filter": 1},
    {"fieldname": "category", "fieldtype": "Select", "label": "Category", "options": "Schedule\nBudget\nResource\nTechnical\nScope\nExternal", "default": "Schedule", "in_list_view": 1, "in_standard_filter": 1},
    {"fieldname": "status", "fieldtype": "Select", "label": "Status", "options": "Open\nMitigated\nClosed\nOccurred", "default": "Open", "in_list_view": 1, "in_standard_filter": 1},
    {"fieldname": "column_break_1", "fieldtype": "Column Break"},
    {"fieldname": "probability", "fieldtype": "Select", "label": "Probability", "options": "Low\nMedium\nHigh", "default": "Medium", "reqd": 1, "in_list_view": 1},
    {"fieldname": "impact", "fieldtype": "Select", "label": "Impact", "options": "Low\nMedium\nHigh", "default": "Medium", "reqd": 1, "in_list_view": 1},
    {"fieldname": "risk_score", "fieldtype": "Int", "label": "Risk Score", "read_only": 1, "in_list_view": 1, "description": "Probability x Impact, on a 1-9 scale"},
    {"fieldname": "owner_user", "fieldtype": "Link", "options": "User", "label": "Risk Owner"},
    {"fieldname": "section_dates", "fieldtype": "Section Break", "label": "Dates"},
    {"fieldname": "identified_date", "fieldtype": "Date", "label": "Identified Date", "default": "Today"},
    {"fieldname": "column_break_2", "fieldtype": "Column Break"},
    {"fieldname": "review_date", "fieldtype": "Date", "label": "Next Review Date"},
    {"fieldname": "section_details", "fieldtype": "Section Break", "label": "Details"},
    {"fieldname": "description", "fieldtype": "Text", "label": "Description"},
    {"fieldname": "mitigation_plan", "fieldtype": "Text", "label": "Mitigation Plan"},
    {"fieldname": "contingency_plan", "fieldtype": "Text", "label": "Contingency Plan"}
  ],
  "permissions": [
    {"role": "Projects Manager", "read": 1, "write": 1, "create": 1, "delete": 1, "submit": 0},
    {"role": "Projects User", "read": 1, "write": 1, "create": 1}
  ]
}
