{
  "name": "Resource Allocation",
  "module": "ProjectFlow",
  "doctype": "DocType",
  "autoname": "naming_series:",
  "naming_series": "RA-.YYYY.-.#####",
  "title_field": "employee_name",
  "sort_field": "creation",
  "sort_order": "DESC",
  "fields": [
    {"fieldname": "naming_series", "fieldtype": "Select", "label": "Series", "options": "RA-.YYYY.-.#####", "hidden": 1},
    {"fieldname": "employee", "fieldtype": "Link", "options": "Employee", "label": "Employee", "reqd": 1, "in_list_view": 1, "in_standard_filter": 1},
    {"fieldname": "employee_name", "fieldtype": "Data", "label": "Employee Name", "fetch_from": "employee.employee_name", "read_only": 1, "in_list_view": 1},
    {"fieldname": "project", "fieldtype": "Link", "options": "Project", "label": "Project", "reqd": 1, "in_list_view": 1, "in_standard_filter": 1},
    {"fieldname": "task", "fieldtype": "Link", "options": "Task", "label": "Task", "depends_on": "eval:doc.project"},
    {"fieldname": "column_break_1", "fieldtype": "Column Break"},
    {"fieldname": "allocation_start_date", "fieldtype": "Date", "label": "Allocation Start Date", "reqd": 1, "in_list_view": 1},
    {"fieldname": "allocation_end_date", "fieldtype": "Date", "label": "Allocation End Date", "reqd": 1, "in_list_view": 1},
    {"fieldname": "allocated_hours_per_day", "fieldtype": "Float", "label": "Allocated Hours / Day", "reqd": 1, "default": "8", "in_list_view": 1},
    {"fieldname": "status", "fieldtype": "Select", "label": "Status", "options": "Planned\nConfirmed\nCompleted", "default": "Planned", "in_list_view": 1, "in_standard_filter": 1},
    {"fieldname": "section_notes", "fieldtype": "Section Break", "label": "Notes"},
    {"fieldname": "notes", "fieldtype": "Small Text", "label": "Notes"}
  ],
  "permissions": [
    {"role": "Projects Manager", "read": 1, "write": 1, "create": 1, "delete": 1, "submit": 0},
    {"role": "Projects User", "read": 1, "write": 1, "create": 1}
  ]
}
